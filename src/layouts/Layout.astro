---
import '@xz/fonts/serve/merriweather.css';
import '@exampledev/new.css/new.css';
import { description, title } from '../common.ts';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={ Astro.generator } />
        <meta name="description" content={ description } />
        <title>{ title }</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
:root {
  --nc-font-serif: 'Merriweather', Georgia, serif;
}
html,input,select,button {
  font-family: var(--nc-font-serif);
  font-size: 1.2em;
}

h1 {
	font-size: 1.45rem;
}

h2 {
	font-size: 1.35rem;
}

h3 {
	font-size: 1.25rem;
}

h4 {
	font-size: 1.15rem;
}
</style>
